# Replace all placeholder values with your real credentials


# vector memory, for semantic search and embeddings storage, using Pinecone
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_HOST=https://your-index-xxxx.svc.region.pinecone.io

# POSTGRESQL, stores user data, conversations, and more
DATABASE_URL=postgresql://username:password@host:5432/database_name

# chat model
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# for protecting routes and generating tokens
PORT=3005

# Generate using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_long_random_secret_key_here

# email
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

